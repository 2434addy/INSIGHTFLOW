# ── InsightFlow Backend Environment Variables ──────────────
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# ── Application ────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
APP_VERSION=0.1.0

# ── Security ───────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-hex-64

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://insightflow:insightflow@localhost:5432/insightflow

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── External Services ─────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_PREMIUM=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TIMEOUT=120

# ── Storage ───────────────────────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
S3_REPORTS_PREFIX=reports/

# ── Pipeline ──────────────────────────────────────────────
PIPELINE_TIMEOUT=300
PIPELINE_MAX_RECORDS=50000
AI_FALLBACK_TO_TEMPLATES=true

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_AUTH=5/15minutes
RATE_LIMIT_API=100/minute
RATE_LIMIT_REPORT_GENERATION=10/hour

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=console
