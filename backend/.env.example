# ── InsightFlow Backend Environment Variables ──────────────
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# ── Application ────────────────────────────────────────────
ENVIRONMENT=development
# ENVIRONMENT=production    # Enables strict security validation
DEBUG=true
# DEBUG=false               # MUST be false in production
APP_VERSION=0.1.0

# ── Security ───────────────────────────────────────────────
# CRITICAL: Generate a real secret key for staging/production:
#   python -c "import secrets; print(secrets.token_hex(64))"
# Must be at least 64 characters (256-bit) in production.
# The app REFUSES TO START in production with the default value.
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-hex-64

# JWT token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing cost factor (12+ recommended)
BCRYPT_ROUNDS=12

# Account lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# ── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed origins. NEVER use "*" in production.
# CORS_ORIGINS=["https://app.insightflow.com"]
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Cookie Security ───────────────────────────────────────
# COOKIE_SECURE=true        # Require HTTPS (auto-relaxed in development)
# COOKIE_SAMESITE=strict    # Prevent CSRF
# COOKIE_DOMAIN=.insightflow.com  # Set to your domain in production

# ── Database ───────────────────────────────────────────────
# Use strong credentials in production. Never use default passwords.
DATABASE_URL=postgresql+asyncpg://insightflow:insightflow@localhost:5432/insightflow
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
# DB_SSL_REQUIRED=true      # Enforce SSL for database connections in production

# ── Redis ──────────────────────────────────────────────────
# Use redis://:password@host:port/db for authenticated connections.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── External Services ─────────────────────────────────────
# Keep API keys out of source control. Use AWS Secrets Manager in production.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_PREMIUM=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TIMEOUT=120

# ── Storage ───────────────────────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
S3_REPORTS_PREFIX=reports/

# ── Pipeline ──────────────────────────────────────────────
PIPELINE_TIMEOUT=300
PIPELINE_MAX_RECORDS=50000
AI_FALLBACK_TO_TEMPLATES=true

# ── Request Limits ────────────────────────────────────────
MAX_REQUEST_BODY_BYTES=1048576

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_AUTH=5/15minutes
RATE_LIMIT_API=100/minute
RATE_LIMIT_REPORT_GENERATION=10/hour

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=console
# LOG_LEVEL=INFO            # Production
# LOG_FORMAT=json           # Production (structured logging)

# ── Allowed Hosts ──────────────────────────────────────────
# ALLOWED_HOSTS=["api.insightflow.com"]   # Set in production. Never use ["*"].
